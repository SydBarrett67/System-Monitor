<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="css/home.css"></link>
</head>
<body onload="start()">
    <div class="main-container">
        <nav class="dashboard">
            <div class="dashboard-element">
                <span>CPU</span>
                <canvas id="cpuChart"></canvas>
            </div>
            <div class="dashboard-element">
                <span>RAM</span>
                <canvas id="ramChart"></canvas>
            </div>
            <div class="dashboard-element">
                <span>GPU</span>
                <canvas id="gpuChart"></canvas>
            </div>
            <div class="dashboard-element">
                <span>Disk</span>
                <canvas id="diskChart"></canvas>
            </div>
            <div class="dashboard-element">
                <span>Ethernet</span>
                <canvas id="netChart"></canvas>
            </div>
        </nav>
        
        <main class="content">
            <h1><%= greeting %></h1>
            <div id="zoom-container" style="flex-grow: 1; min-height: 400px; padding: 20px; background: rgba(255,255,255,0.05); border-radius: 8px;">
                <h3 id="zoom-title" style="color: #888; margin-top: 0;">Seleziona un grafico per lo zoom</h3>
                <canvas id="zoomChart"></canvas>
            </div>
        </main>

        <div class="nav-container">
            <a href="/exportPage" class="nav-btn">
                <span style="margin-right: 6px;"></span> Esporta Logs
            </a>
            <a href="/log" class="nav-btn">
                <span style="margin-right: 6px;"></span> Visualizza Logs
            </a>
        </div>
    </div>


    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const refreshDelay = parseInt("<%= delay %>") || 3000;;
    </script>
    <script src="js/home.js"></script>
</body>
</html>